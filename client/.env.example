# ============================================
# Frontend Environment — Template
# ============================================
# Copy this file to .env.development or .env.production
# and update the values

# Node.js Backend (Express Server)
# Development: http://localhost:5000
# Production: https://api.your-domain.com
VITE_API_URL=http://localhost:5000

# Python Backend (FastAPI)
# Development: http://localhost:8000
# Production: https://rag-api.your-domain.com
VITE_AI_URL=http://localhost:8000

# App Configuration
VITE_APP_NAME=IntegratedGov AI
VITE_APP_ENV=development
VITE_DEBUG=true
VITE_LOG_LEVEL=debug

# Feature Flags (true/false)
VITE_ENABLE_VOICE_INPUT=true
VITE_ENABLE_PDF_EXPORT=true
VITE_ENABLE_MULTILANG=true

# Analytics & Monitoring (Optional)
# Get these from your analytics provider dashboards
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx
# VITE_GA_ID=G-XXXXXXXXXXXX
